generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  ADMIN
  TREINADOR
}

enum StatusSolicitacao {
  PENDENTE
  APROVADA
  RECUSADA
}

enum StatusPartida {
  AGENDADA
  AO_VIVO
  ENCERRADA
  ADIADA
}

enum TipoEvento {
  GOL
  CARTAO_AMARELO
  CARTAO_VERMELHO
  SUBSTITUICAO
  OUTRO
}

enum Posicao {
  GOLEIRO
  FIXO
  ALA
  PIVO
  LINHA
}

enum FormatoDisputa {
  PONTOS_CORRIDOS
  GRUPOS_MATA_MATA
}

enum FasePartida {
  GRUPOS
  OITAVAS
  QUARTAS
  SEMIFINAL
  TERCEIRO_LUGAR
  FINAL
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  role          Role     @default(TREINADOR)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  times         Time[]
  solicitacoes  SolicitacaoTime[]
  eventosLancados EventoPartida[] @relation("EventosLancadosPor")
}

model Campeonato {
  id             String   @id @default(cuid())
  nome           String
  temporada      String
  ativo          Boolean  @default(true)
  regulamentoUrl String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  categorias  Categoria[]
}

model Categoria {
  id                    String   @id @default(cuid())
  nome                  String
  campeonatoId          String
  campeonato            Campeonato @relation(fields: [campeonatoId], references: [id], onDelete: Cascade)
  formato               FormatoDisputa @default(PONTOS_CORRIDOS)
  classificadosPorGrupo Int?
  cartoesParaSuspensao  Int      @default(3)
  jogosSuspensao        Int      @default(1)
  regulamentoUrl        String?
  createdAt             DateTime @default(now())

  times       Time[]
  partidas    Partida[]
  grupos      Grupo[]
  enquetes    Enquete[]

  @@unique([campeonatoId, nome])
}

model Grupo {
  id          String   @id @default(cuid())
  nome        String
  categoriaId String
  categoria   Categoria @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  times       Time[]

  @@unique([categoriaId, nome])
}

model Time {
  id            String   @id @default(cuid())
  nome          String
  escudoUrl     String?
  categoriaId   String
  categoria     Categoria @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
  grupoId       String?
  grupo         Grupo?   @relation(fields: [grupoId], references: [id])
  treinadorId   String?
  treinador     User?    @relation(fields: [treinadorId], references: [id])
  conviteToken  String   @unique @default(cuid())
  createdAt     DateTime @default(now())

  atletas       Atleta[]
  partidasCasa  Partida[] @relation("TimeCasa")
  partidasFora  Partida[] @relation("TimeFora")
  eventos       EventoPartida[]
  solicitacoes  SolicitacaoTime[]
  inscricoes    InscricaoAtleta[]
}

model SolicitacaoTime {
  id          String   @id @default(cuid())
  nomeTime    String
  treinadorId String
  treinador   User     @relation(fields: [treinadorId], references: [id], onDelete: Cascade)
  timeId      String?
  time        Time?    @relation(fields: [timeId], references: [id])
  categoriaId String?
  status      StatusSolicitacao @default(PENDENTE)
  mensagem    String?
  createdAt   DateTime @default(now())
}

model Atleta {
  id            String   @id @default(cuid())
  nome          String
  numero        Int
  posicao       Posicao
  fotoUrl       String?
  documentoUrl  String?
  comprovanteEnderecoUrl String?
  dataNascimento DateTime?
  instagram     String?
  timeId        String
  time          Time     @relation(fields: [timeId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  eventos       EventoPartida[]
  inscricao     InscricaoAtleta?
  votosRecebidos EnqueteOpcao[]

  @@unique([timeId, numero])
}

enum StatusInscricao {
  PENDENTE
  APROVADA
  RECUSADA
}

model InscricaoAtleta {
  id                      String   @id @default(cuid())
  timeId                  String
  time                    Time     @relation(fields: [timeId], references: [id], onDelete: Cascade)
  nome                    String
  dataNascimento          DateTime
  instagram               String?
  fotoUrl                 String
  documentoUrl            String
  comprovanteEnderecoUrl  String
  status                  StatusInscricao @default(PENDENTE)
  atletaId                String?  @unique
  atleta                  Atleta?  @relation(fields: [atletaId], references: [id])
  createdAt               DateTime @default(now())
  revisadoEm              DateTime?
}

model Partida {
  id            String   @id @default(cuid())
  categoriaId   String
  categoria     Categoria @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
  timeCasaId    String
  timeCasa      Time     @relation("TimeCasa", fields: [timeCasaId], references: [id])
  timeForaId    String
  timeFora      Time     @relation("TimeFora", fields: [timeForaId], references: [id])
  rodada        Int?
  fase          FasePartida @default(GRUPOS)
  dataHora      DateTime
  local         String?
  status        StatusPartida @default(AGENDADA)
  placarCasa    Int      @default(0)
  placarFora    Int      @default(0)
  golsCasaDetalhe Int?
  linkTransmissaoUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  eventos       EventoPartida[]
}

model EventoPartida {
  id          String   @id @default(cuid())
  partidaId   String
  partida     Partida  @relation(fields: [partidaId], references: [id], onDelete: Cascade)
  tipo        TipoEvento
  minuto      Int
  timeId      String
  time        Time     @relation(fields: [timeId], references: [id])
  atletaId    String?
  atleta      Atleta?  @relation(fields: [atletaId], references: [id])
  descricao   String?
  videoUrl    String?
  lancadoPorId String?
  lancadoPor  User?    @relation("EventosLancadosPor", fields: [lancadoPorId], references: [id])
  createdAt   DateTime @default(now())
}

model Enquete {
  id          String   @id @default(cuid())
  categoriaId String
  categoria   Categoria @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
  rodada      Int
  pergunta    String   @default("Melhor Jogador da Rodada")
  ativa       Boolean  @default(true)
  createdAt   DateTime @default(now())

  opcoes      EnqueteOpcao[]
  votos       EnqueteVoto[]
}

model EnqueteOpcao {
  id        String   @id @default(cuid())
  enqueteId String
  enquete   Enquete  @relation(fields: [enqueteId], references: [id], onDelete: Cascade)
  atletaId  String
  atleta    Atleta   @relation(fields: [atletaId], references: [id])

  votos     EnqueteVoto[]

  @@unique([enqueteId, atletaId])
}

model EnqueteVoto {
  id        String   @id @default(cuid())
  enqueteId String
  enquete   Enquete  @relation(fields: [enqueteId], references: [id], onDelete: Cascade)
  opcaoId   String
  opcao     EnqueteOpcao @relation(fields: [opcaoId], references: [id], onDelete: Cascade)
  deviceId  String
  createdAt DateTime @default(now())

  @@unique([enqueteId, deviceId])
}

model PushSubscription {
  id            String   @id @default(cuid())
  endpoint      String   @unique
  p256dh        String
  auth          String
  categoriaId   String?
  timeId        String?
  lembreteMin   Int?     @default(30)
  createdAt     DateTime @default(now())
}
